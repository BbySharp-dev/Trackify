{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "<Replace-with-User-Secret>"
  },
  "Jwt": {
    "Key": "<Replace-with-User-Secret>",
    "Issuer": "Trackify",
    "Audience": "Trackify",
    "ExpirationInMinutes": 60
  },
  "Scraping": {
    "IntervalHours": 6,
    "DelayBetweenRequestsMs": 3000,
    "MaxConcurrentRequests": 2
  }
}